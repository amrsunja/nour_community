<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash (dark mode). Without this file it defaults to white/system. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/splash_color</item>
        <item name="android:windowBackground">@color/splash_color</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_color</item>
    </style>
</resources>
